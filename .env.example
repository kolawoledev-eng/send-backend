# Server
NODE_ENV=development
PORT=3000

# Database (Railway Postgres – set when you add Postgres plugin)
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Stellar / Soroban (mainnet when ready)
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Mainnet (uncomment when switching)
# STELLAR_NETWORK=public
# SOROBAN_RPC_URL=https://soroban-mainnet.stellar.org
# STELLAR_HORIZON_URL=https://horizon.stellar.org

# Optional: server signing key for fee bump / sponsorship (base64 secret)
# STELLAR_SERVER_SECRET_KEY=

# SEP-24 Anchor Platform (NGN → USDC on-ramp). Deploy Anchor Platform separately (e.g. Docker).
# ANCHOR_PLATFORM_SERVER=https://anchor.yourdomain.com
# ANCHOR_HOME_DOMAIN=yourdomain.com
# SECRET_SEP24_INTERACTIVE_JWT_SECRET=  # Must match Platform's JWT secret for interactive URL
# USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=*
